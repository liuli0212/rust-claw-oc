#!/usr/bin/env bash
set -euo pipefail
# Restart rusty-claw with the newest already-built binary. Does not pull/build.
# Usage: scripts/restart-rusty-claw [--dry-run] [--pid PID] [-- args...]
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_NAME="rusty-claw"
LOG_DIR="$ROOT/logs/restart"
HELPER="$ROOT/.tmp/restart-rusty-claw-helper.sh"
bin_path() {
    local release="$ROOT/target/release/$BIN_NAME"
    local debug="$ROOT/target/debug/$BIN_NAME"
    if [[ -x "$release" && ( ! -x "$debug" || "$release" -nt "$debug" ) ]]; then
        echo "$release"
    elif [[ -x "$debug" ]]; then
        echo "$debug"
    else
        echo "No built $BIN_NAME found. Run cargo build first." >&2
        exit 1
    fi
}
cmd_for_pid() {
    ps -p "$1" -o command= 2>/dev/null | sed 's/^[[:space:]]*//'
}
find_pid() {
    local p="${PPID:-}"
    while [[ -n "$p" && "$p" != "0" && "$p" != "1" ]]; do
        local c
        c="$(cmd_for_pid "$p" || true)"
        if [[ "$c" == *"/$BIN_NAME"* || "$c" == "$BIN_NAME"* ]]; then
            echo "$p"
            return
        fi
        p="$(ps -p "$p" -o ppid= 2>/dev/null | tr -d '[:space:]')"
    done
}
args_from_cmd() {
    python3 -c 'import shlex,sys; sys.stdout.write("".join(a+"\0" for a in shlex.split(sys.argv[1])[1:]))' "$1"
}
main() {
    local old_pid old_cmd bin log dry_run=0
    local args=()
    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            --dry-run) dry_run=1; shift ;;
            --pid) old_pid="${2:-}"; [[ -n "$old_pid" ]] || { echo "--pid requires a value" >&2; exit 1; }; shift 2 ;;
            --) shift; args=("$@"); break ;;
            *) args=("$@"); break ;;
        esac
    done
    bin="$(bin_path)"
    old_pid="${old_pid:-$(find_pid || true)}"
    if [[ -z "$old_pid" && "$dry_run" == "1" ]]; then
        old_pid=999999
        old_cmd="$BIN_NAME"
    elif [[ -n "$old_pid" ]]; then
        old_cmd="$(cmd_for_pid "$old_pid" || true)"
    else
        echo "No running $BIN_NAME found." >&2
        exit 1
    fi
    if [[ "${#args[@]}" -eq 0 ]]; then
        while IFS= read -r -d '' a; do args+=("$a"); done < <(args_from_cmd "$old_cmd")
    fi
    mkdir -p "$LOG_DIR" "$(dirname "$HELPER")"
    log="$LOG_DIR/restart-$(date +%Y%m%d-%H%M%S).log"
    {
        printf '#!/usr/bin/env bash\nset -euo pipefail\n'
        printf 'kill -TERM %q 2>/dev/null || true\n' "$old_pid"
        printf 'for _ in {1..100}; do kill -0 %q 2>/dev/null || break; sleep 0.1; done\n' "$old_pid"
        printf 'kill -0 %q 2>/dev/null && { echo "old process did not exit" >>%q; exit 1; }\n' "$old_pid" "$log"
        printf 'cd %q\n' "$ROOT"
        printf 'exec %q' "$bin"
        ((${#args[@]})) && printf ' %q' "${args[@]}"
        printf ' >>%q 2>&1\n' "$log"
    } >"$HELPER"
    chmod +x "$HELPER"
    if [[ "$dry_run" == "1" ]]; then
        echo "Dry run only. Would restart old PID $old_pid with:"
        printf '  %q' "$bin"
        ((${#args[@]})) && printf ' %q' "${args[@]}"
        echo
        echo "Generated helper:"
        sed 's/^/  /' "$HELPER"
        echo "Log would be: $log"
        exit 0
    fi
    nohup "$HELPER" >/dev/null 2>&1 &
    echo "Restart armed: old PID $old_pid will stop, then $bin will start."
    echo "Log: $log"
}
main "$@"
